generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── EMPRESAS ──────────────────────────────────────────────────────────────────
model Empresa {
  id          Int          @id @default(autoincrement())
  nombre      String       @unique
  subempresas Subempresa[]
  cajas       Caja[]
  movimientos Movimiento[]
  creadoEn    DateTime     @default(now())
}

model Subempresa {
  id          Int          @id @default(autoincrement())
  nombre      String
  empresaId   Int
  empresa     Empresa      @relation(fields: [empresaId], references: [id])
  movimientos Movimiento[]
  creadoEn    DateTime     @default(now())
}

// ── CAJAS ─────────────────────────────────────────────────────────────────────
model Caja {
  id             Int               @id @default(autoincrement())
  nombre         String
  locacion       String
  saldo          Float             @default(0)
  empresaId      Int
  empresa        Empresa           @relation(fields: [empresaId], references: [id])
  movimientos    Movimiento[]
  transferencias TransferenciaCaja[] @relation("CajaOrigen")
  recibidas      TransferenciaCaja[] @relation("CajaDestino")
  activa         Boolean           @default(true)
  creadoEn       DateTime          @default(now())
}

model TransferenciaCaja {
  id           Int      @id @default(autoincrement())
  cajaOrigenId Int
  cajaDestino  Int
  monto        Float
  concepto     String?
  usuarioId    Int
  usuario      Usuario  @relation(fields: [usuarioId], references: [id])
  origen       Caja     @relation("CajaOrigen", fields: [cajaOrigenId], references: [id])
  destino      Caja     @relation("CajaDestino", fields: [cajaDestino], references: [id])
  creadoEn     DateTime @default(now())
}

// ── USUARIOS ──────────────────────────────────────────────────────────────────
model Usuario {
  id               Int       @id @default(autoincrement())
  nombre           String
  email            String    @unique
  password         String
  rol              String    @default("OPERATIVO")
  activo           Boolean   @default(true)
  creadoEn         DateTime  @default(now())
  movimientos      Movimiento[]
  auditorias       Auditoria[]
  transferencias   TransferenciaCaja[]
}

// ── CLAVES ────────────────────────────────────────────────────────────────────
model Clave {
  id          Int          @id @default(autoincrement())
  codigo      String       @unique
  descripcion String
  categoria   String?
  activa      Boolean      @default(true)
  movimientos Movimiento[]
  creadoEn    DateTime     @default(now())
}

// ── MOVIMIENTOS ───────────────────────────────────────────────────────────────
model Movimiento {
  id           Int        @id @default(autoincrement())
  fecha        DateTime   @default(now())
  tipo         String
  monto        Float
  concepto     String
  persona      String
  empresaId    Int
  empresa      Empresa    @relation(fields: [empresaId], references: [id])
  subempresaId Int?
  subempresa   Subempresa? @relation(fields: [subempresaId], references: [id])
  cajaId       Int
  caja         Caja       @relation(fields: [cajaId], references: [id])
  claveId      Int?
  clave        Clave?     @relation(fields: [claveId], references: [id])
  usuarioId    Int
  usuario      Usuario    @relation(fields: [usuarioId], references: [id])
  socioId      Int?
  socio        Socio?     @relation(fields: [socioId], references: [id])
  proveedorId  Int?
  proveedor    Proveedor? @relation(fields: [proveedorId], references: [id])
  creadoEn     DateTime   @default(now())
}

// ── SOCIOS ────────────────────────────────────────────────────────────────────
model Socio {
  id          Int           @id @default(autoincrement())
  nombre      String
  movimientos Movimiento[]
  retiros     RetiroSocio[]
  creadoEn    DateTime      @default(now())
}

model RetiroSocio {
  id         Int      @id @default(autoincrement())
  socioId    Int
  socio      Socio    @relation(fields: [socioId], references: [id])
  monto      Float
  tipoCambio Float
  montoUsd   Float
  mes        Int
  anio       Int
  creadoEn   DateTime @default(now())
}

model DiferenciaSocios {
  id              Int      @id @default(autoincrement())
  mes             Int
  anio            Int
  socioDeudorId   Int
  socioAcreedor   Int
  diferenciaMxn   Float
  tipoCambio      Float
  diferenciaUsd   Float
  cerrado         Boolean  @default(false)
  creadoEn        DateTime @default(now())
}

// ── PROVEEDORES ───────────────────────────────────────────────────────────────
model Proveedor {
  id             Int                      @id @default(autoincrement())
  nombre         String
  comision       Float
  movimientos    Movimiento[]
  transferencias TransferenciaProveedor[]
  creadoEn       DateTime                 @default(now())
}

model TransferenciaProveedor {
  id            Int      @id @default(autoincrement())
  proveedorId   Int
  proveedor     Proveedor @relation(fields: [proveedorId], references: [id])
  montoEnviado  Float
  montoEsperado Float
  montoRecibido Float    @default(0)
  pendiente     Float
  comision      Float
  liquidado     Boolean  @default(false)
  creadoEn      DateTime @default(now())
}

// ── AUDITORÍA ─────────────────────────────────────────────────────────────────
model Auditoria {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  accion     String
  modulo     String
  detalle    String?
  ip         String?
  creadoEn   DateTime @default(now())
}
